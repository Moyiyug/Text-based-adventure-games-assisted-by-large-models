# === DeepSeek ===
# 勿加引号；勿留行尾空格。
# 若入库报 401：Windows「用户/系统环境变量」里的 DEEPSEEK_API_KEY 会覆盖本文件（含已废弃的旧 Key）；删错变量或改成当前有效 Key 后需重开终端/IDE。
DEEPSEEK_API_KEY=sk-xxx
# 官方文档两种均可：https://api.deepseek.com 或 https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === Narrative（可选）===
# true 时开场落库前额外调用一次 DeepSeek 软化叙事正文；流式回合不软化（避免与已推送 token 不一致）。
NARRATIVE_SAFETY_SOFTEN=false
# true 时：结构化 choices 与正文编号均未命中后，再调用 DeepSeek 生成选项（可 false 节省成本）。
NARRATIVE_CHOICES_LLM_FALLBACK=true
# 传入选项抽取模型的叙事尾部最大字符数。
NARRATIVE_CHOICES_LLM_MAX_INPUT_CHARS=3500
# 回合推进提示（注入 prompt，不展示给玩家）
NARRATIVE_TURN_HINTS_ENABLED=true
NARRATIVE_STALL_BREAK_ENABLED=true
NARRATIVE_STALL_SIMILARITY_THRESHOLD=0.55
# true 时多一次 DeepSeek，仅改 prompt 内玩家块，落库 user 仍为原文
NARRATIVE_INPUT_BRIDGE=false
# true 且 strict 时主流后再精炼 choices/choice_beats（多一次 DeepSeek）
NARRATIVE_STRICT_CHOICE_REFINE=false
# true 时：第一轮叙事+META(state) 后，再用同一检索证据块专call 一次生成 choices（减正文选项泄漏；成功则 metadata.choices_source=llm_rag_split，且跳过 STRICT_CHOICE_REFINE）
NARRATIVE_SPLIT_CHOICES_LLM=false
# true：第一轮只叙事、第二轮专出 META（优先于 NARRATIVE_SPLIT_CHOICES_LLM）
NARRATIVE_TWO_PHASE_ENABLED=false

# --- 可选：scripts/narrative_llm_roundtrip_soak.py 真实 LLM 多轮测试（不设则不用）---
# SOAK_API_BASE=http://127.0.0.1:8000
# SOAK_HTTP_TIMEOUT=300
# SOAK_USERNAME=
# SOAK_PASSWORD=
# SOAK_STORY_ID=1
# SOAK_ROUNDS=10
# SOAK_OPENING_GOAL=
# SOAK_MODE=strict
# true 时在 system 末尾追加一句篇幅软提示（略短叙事/选项，非硬截断）
NARRATIVE_CONCISE_MODE=true

# === Profile / 画像推断（Phase 5）===
# true 时每 N 轮 SSE 落库成功后异步调用 DeepSeek 更新 user_profiles / story_profiles（费 token）
PROFILE_INFERENCE_ENABLED=false
PROFILE_INFERENCE_EVERY_N_TURNS=4
PROFILE_INFERENCE_HISTORY_MESSAGES=24
PROFILE_INFERENCE_TEMPERATURE=0.2
# 角色卡 JSON 上传最大字节数
PROFILE_IMPORT_MAX_BYTES=262144

# === Eval / 评测（Phase 6，可选）===
# EVAL_MAX_CASES_PER_RUN=24
# EVAL_CONTEXT_TOKEN_BUDGET=6000
# EVAL_GENERATE_TIMEOUT=120
# EVAL_ANSWER_TIMEOUT=90
# EVAL_JUDGE_TIMEOUT=90

# === SiliconFlow Embedding ===
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///../data/app.db

# === ChromaDB ===
CHROMA_PERSIST_DIR=../data/chroma

# === Upload ===
UPLOAD_DIR=../data/uploads

# === JWT ===
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# === App ===
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173
